# ============================================
# AdaptLab Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://adaptlab:adaptlab@db:5432/adaptlab

# ---------- Kimi API (Moonshot AI) ----------
KIMI_API_KEY=your-kimi-api-key-here
KIMI_MODEL=moonshot-v1-8k

# ---------- JWT Authentication ----------
JWT_SECRET=your-jwt-secret-change-this-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ---------- Judge0 Code Execution ----------
JUDGE0_URL=http://judge0:2358

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
